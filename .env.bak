# Required
PORTFOLIO_MASTER_KEY=cochranblock-master-key-32-chars!!

# Cloudflare (DNS, SSL at edge — origin can be HTTP with Flexible, or HTTPS with Origin Cert)
# Token needs Zone.DNS Edit, Zone.Zone Read, Zone.Single Redirect Edit, Zone.Zone Settings Edit
CLOUDFLARE_API_TOKEN=HTTNcDXqQ_nSR4Gnzo6saCVa2aWRvXwLmtxe9P-8
# Account that owns the tunnel (from oakilydokily.com zone); required for --update-tunnel
CLOUDFLARE_ACCOUNT_ID=aabaf34b42d0d042e3e570903b117b08

# 0.0.0.0 = reachable on internal network; 127.0.0.1 = localhost only
PORTFOLIO_PORT=443
PORTFOLIO_BIND=0.0.0.0

PORTFOLIO_DATA_DIR=data

# portfolio-router: hostnames that route to Kaylie (kaylie-portfolio on 3000)
ROUTER_KAYLIE_HOST=oakilydokily.com,www.oakilydokily.com

# Approuter self-registration
ROUTER=http://127.0.0.1:8080

# For auto HTTPS (Caddy-like): domain + Cloudflare token.
PORTFOLIO_DOMAIN=cochranblock.org,www.cochranblock.org
