# === Required for static cochranblock (cochranblock.org) ===
# All have defaults. Override only if needed.
# PORT=8081
# BIND=0.0.0.0
# CB_HOSTNAMES=cochranblock.org,www.cochranblock.org
# CB_BACKEND_URL=http://127.0.0.1:8081
# COCHRANBLOCK_ROOT=  # If set, .env loaded from $COCHRANBLOCK_ROOT/.env

# === Required for admin/dns (when wired) ===
PORTFOLIO_MASTER_KEY=your-master-key-at-least-16-chars

# e: R U CH OH CP OP RP TP. Run: approuter env-print

# Cloudflare (DNS + SSL at edge — origin HTTP or HTTPS with Origin Cert)
# Get token: Cloudflare Dashboard → My Profile → API Tokens → Create Token
# Permissions: Zone.DNS Edit, Zone.Zone Read
CLOUDFLARE_API_TOKEN=
# GitHub (PAT or fine-grained token). For runner/scripts that call GitHub API.
# GITHUB_TOKEN=

# RESEND_DKIM=  # For runner setup-resend-dns (get from resend.com/domains after adding roguerepo.io)

# Google API (service account JSON). Run: approuter setup-google-sa
# GOOGLE_APPLICATION_CREDENTIALS=$HOME/.config/gcloud/workspace-sa.json

# === Optional for admin/dns ===
# HTTPS: run --gen-self-signed (local) or --acme (Let's Encrypt)
# After certs in data dir, server auto-uses HTTPS. Default: XDG data dir (~/.local/share/cochranblock/).
# PORTFOLIO_PORT=443
# PORTFOLIO_BIND=0.0.0.0
# Second interface: same app also listens here (e.g. WSL or internal). Set both.
# PORTFOLIO_BIND_2=0.0.0.0
# PORTFOLIO_PORT_2=8443
# PORTFOLIO_DATA_DIR=  # default: ~/.local/share/cochranblock/portfolio
# PORTFOLIO_CF_BASE=https://api.cloudflare.com/client/v4
# PORTFOLIO_IPIFY_URL=https://api.ipify.org
# PORTFOLIO_DNS_INTERVAL=300

# ROUTER_CONFIG_DIR=  # default: ~/.local/share/cochranblock/approuter
# router (tunnel target). Must match cloudflared config ingress port.
# ROUTER_PORT=8080
# ROUTER=http://127.0.0.1:8080  # For cochranblock approuter self-registration
# ROUTER_KAYLIE_HOST=oakilydokily.com,www.oakilydokily.com
# ROUTER_ROGUEREPO_HOST=roguerepo.io,www.roguerepo.io
# ROUTER_ROGUEREPO_URL=http://127.0.0.1:3001
